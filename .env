# ---------------------------------------------------------------------------
# Database (SQLite สำหรับ Demo)
# เปลี่ยนเป็น MySQL/PostgreSQL ได้โดยแก้ provider ใน prisma/schema.prisma
# แล้วเปลี่ยน DATABASE_URL เป็น connection string ของฐานข้อมูลนั้น
#   MySQL:      mysql://user:pass@localhost:3306/ge
#   PostgreSQL: postgresql://user:pass@localhost:5432/ge?schema=public
# ---------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# ---------------------------------------------------------------------------
# Session (iron-session) — ต้องยาวอย่างน้อย 32 ตัวอักษร
# โปรดเปลี่ยนค่านี้ก่อนใช้งานจริง
# ---------------------------------------------------------------------------
SESSION_SECRET="change_this_to_a_long_random_secret_at_least_32_chars_1234"

# บัญชีผู้ดูแลระบบเริ่มต้น (ใช้ตอน seed)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
